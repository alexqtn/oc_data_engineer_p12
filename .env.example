# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sportdb
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_password
POSTGRES_WRITER_USER=your_writer_user
POSTGRES_WRITER_PASSWORD=your_writer_password
POSTGRES_READER_USER=your_reader_user
POSTGRES_READER_PASSWORD=your_reader_password
POSTGRES_EXTERNAL_PORT=5432
POSTGRES_EXTERNAL_HOST=localhost
ENCRYPTION_KEY=your_secret_encryption_key

# Redpanda
REDPANDA_BROKERS=redpanda:9092
REDPANDA_EXTERNAL_BROKER=localhost:19092
REDPANDA_EXTERNAL_PORT=19092
REDPANDA_CONSOLE_PORT=8090

# Slack
SLACK_WEBHOOK_URL=your_webhook_url

# Google Maps
GOOGLE_MAPS_API_KEY=your_api_key

# Kestra
KESTRA_URL=http://kestra:8080
KESTRA_EXTERNAL_PORT=8080
KESTRA_POSTGRES_USER=your_kestra_user
KESTRA_POSTGRES_PASSWORD=your_kestra_password

# Metabase
METABASE_EXTERNAL_PORT=3000
METABASE_POSTGRES_USER=metabase_user
METABASE_POSTGRES_PASSWORD=your_metabase_password